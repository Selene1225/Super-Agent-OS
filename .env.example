# Super-Agent-OS Environment Variables
# Copy this file to .env and fill in your values

# === Primary Model Selection ===
# Which model to use first: qwen | deepseek | doubao
PRIMARY_MODEL=qwen

# === LLM: Qwen (通义千问) ===
QWEN_API_KEY=sk-xxxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# === LLM: DeepSeek ===
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# === LLM: Doubao (豆包 / 火山引擎) ===
DOUBAO_API_KEY=xxxx
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-32k

# === Feishu Bot (WebSocket mode — no public URL needed) ===
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx

# === Feishu Bitable (多维表格 — 用于存储提醒等结构化数据) ===
# 从多维表格URL中获取: https://xxx.feishu.cn/base/<APP_TOKEN>?table=<TABLE_ID>
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_REMINDER_TABLE_ID=

# === Server ===
LOG_LEVEL=INFO
